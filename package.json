{
  "name": "acp-claw",
  "version": "1.0.0",
  "description": "Turn Any ACP Coding Agent into a Long-Lived Claw",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "acp-claw": "./dist/cli.js"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rslib",
    "check": "biome check --write",
    "dev": "rslib --watch",
    "format": "biome format --write",
    "start": "node dist/cli.js",
    "test": "rstest",
    "test:watch": "rstest --watch",
    "version:patch": "npm --no-git-tag-version version patch"
  },
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.64.0",
    "commander": "^13.1.0",
    "cron-parser": "^5.5.0",
    "node-cron": "^4.2.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "@rslib/core": "^0.21.5",
    "@rstest/adapter-rslib": "^0.2.2",
    "@rstest/core": "^0.9.10",
    "@types/node": "^24.12.4",
    "@types/node-cron": "^3.0.11",
    "typescript": "^6.0.3"
  },
  "keywords": [
    "acp",
    "agent",
    "ai",
    "coding-assistant",
    "feishu",
    "lark"
  ],
  "author": "IanYu",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/IanYu-Tree/acp-claw.git"
  },
  "homepage": "https://github.com/IanYu-Tree/acp-claw"
}
